# K9 Environment Variables 
# Copy to .env.local and fill in your values 
 
# Backend API (optional — app works without it, uses clipboard fallback) 
VITE_API_URL=https://your-backend.railway.app 
 
# Vercel Analytics (optional) 
VITE_ANALYTICS_ID= 
 
# App URL (used for OG tags and deep links) 
VITE_APP_URL=https://k9.app 
