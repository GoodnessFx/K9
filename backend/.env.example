# Copy this file to .env — NEVER commit .env to git 
 
# Server Config
NODE_ENV=production
PORT=3001
API_SECRET=your-32-character-api-secret-here
FRONTEND_URL=https://k9-frontend.vercel.app

# AI (Required)
ANTHROPIC_API_KEY=sk-ant-your-key-here 
 
# Cache & Queue (Required - Upstash Redis recommended)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Telegram (Required)
TELEGRAM_BOT_TOKEN=your-bot-token-here 
# TELEGRAM_WEBHOOK_URL=https://your-backend.railway.app/api/telegram-webhook

# WhatsApp (Optional)
GREEN_API_INSTANCE_ID=your-instance-id 
GREEN_API_TOKEN=your-token-here 
MY_WHATSAPP_NUMBER=your-number-with-country-code 
 
# Optional Data Sources & Security APIs
GITHUB_TOKEN= 
ETHERSCAN_API_KEY= 
COINGECKO_API_KEY= 
IMMUNEFI_API_KEY=
BIRDEYE_API_KEY=
GOPLUS_API_KEY=

# Signal Engine Config (Optional overrides)
# SIGNAL_SCAN_INTERVAL_MINUTES=5
# MIN_SIGNAL_SCORE=65
# MAX_SIGNALS_PER_BATCH=20

# Proxy Config (Optional for stealth scraping)
# PROXY_PROVIDER=brightdata
# PROXY_USERNAME=
# PROXY_PASSWORD=
# PROXY_ENDPOINT=
